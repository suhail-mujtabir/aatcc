          },
          {
            "row": 3,
            "col": 3
          }
        ]
      },
      {
        "title": "2-Thread Grouping",
        "description": "Warp threads float over 2 weft threads, creating the characteristic twill diagonal.",
        "highlightType": "cells",
        "highlightCells": [
          {
            "row": 0,
            "col": 0
          },
          {
            "row": 0,
            "col": 1
          }
        ]
      },
      {
        "title": "Reversible Pattern",
        "description": "Twill is reversible - the back shows the opposite pattern. Used in denim, chino, and herringbone fabrics.",
        "highlightType": "none"
      }
    ]
  },
