{
  "plain-weave": {
    "steps": [
      {
        "title": "Plain Weave Basics",
        "description": "Plain weave is the simplest weave structure. Each warp thread alternates over and under each weft thread.",
        "highlightType": "none"
      },
      {
        "title": "Warp Threads",
        "description": "Vertical warp threads form the foundation. Notice how they alternate in the pattern.",
        "highlightType": "warp",
        "highlightIndex": 0
      },
      {
        "title": "Weft Threads",
        "description": "Horizontal weft threads weave through the warp in an alternating pattern.",
        "highlightType": "weft",
        "highlightIndex": 0
      },
      {
        "title": "Checkerboard Pattern",
        "description": "This creates a balanced checkerboard structure. Each intersection alternates between warp (1) and weft (0) on top.",
        "highlightType": "cells",
        "highlightCells": [
          {
            "row": 0,
            "col": 0
          },
          {
            "row": 0,
            "col": 2
          },
          {
            "row": 1,
            "col": 1
          },
          {
            "row": 1,
            "col": 3
          }
        ]
      },
      {
        "title": "Maximum Interlacement",
        "description": "Plain weave has the most interlacement points, making it strong and durable. Perfect for shirts, sheets, and canvas.",
        "highlightType": "none"
      }
    ]
  },
  "twill-2-2": {
    "steps": [
      {
        "title": "Twill 2/2 Structure",
        "description": "Twill weaves create diagonal lines. The 2/2 means 2 warp threads up, then 2 down.",
        "highlightType": "none"
      },
      {
        "title": "Diagonal Line Formation",
        "description": "Notice the diagonal pattern moving from bottom-left to top-right. Each row shifts the pattern by one thread.",
        "highlightType": "cells",
